# AnyKernel3 内核打包工具源码（官方通用仓库）
ANYKERNEL_SOURCE=https://github.com/osm0sis/AnyKernel3.git
# AnyKernel3 稳定分支
ANYKERNEL_SOURCE_BRANCH=master

# 你的设备内核源码（LineageOS 官方内核）
KERNEL_SOURCE=https://github.com/LineageOS/android_kernel_motorola_sm8250.git
# 内核源码对应分支（LineageOS 23.2 专属）
KERNEL_SOURCE_BRANCH=lineage-23.2

# 设备专属内核配置文件（Moto Edge S 唯一默认配置）
KERNEL_CONFIG=lineageos_nio_defconfig

# 内核编译参数（arm64 架构 + 安卓交叉编译链，通用固定写法）
BUILD_ARGS=ARCH=arm64 CROSS_COMPILE=aarch64-linux-android-
